services:

  # ── h2o server ─────────────────────────────────────────────────────────────
  # Built from local source. Serves payloads pre-generated by
  # scripts/generate-payloads.sh (or auto-generates missing ones at startup).
  server:
    build:
      context: ..
      dockerfile: docker/Dockerfile.server
    container_name: h2o-server
    ports:
      - "8080:8080"        # HTTP  (TCP — HTTP/1.1)
      - "8443:8447"        # HTTPS (TCP — HTTP/1.1 + HTTP/2)
      - "8444:8444/udp"    # QUIC  (UDP — HTTP/3)
    volumes:
      - ./payloads:/srv/static   # pre-generated payload files
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:8080/1mb.bin", "-o", "/dev/null"]
      interval: 5s
      timeout: 10s
      retries: 24
      start_period: 10s
  
#Pico
